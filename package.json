{
  "name": "partnership_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:hybrid": "sh -c 'PORT=${PORT:-3101}; BETTER_AUTH_URL=http://localhost:$PORT NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:$PORT next dev -p $PORT'",
    "backend:up": "docker compose up -d --wait db",
    "backend:init": "npm run db:push && npm run db:seed",
    "hybrid:prepare": "npm run backend:up && npm run backend:init",
    "backend:down": "docker compose down",
    "backend:logs": "docker compose logs db --tail=100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@prisma/client": "^6.6.0",
    "better-auth": "^1.2.8",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.4.49",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
